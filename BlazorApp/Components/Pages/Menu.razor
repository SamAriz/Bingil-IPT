@page "/lifecycle/menu"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components

<PageTitle>Sample Menu</PageTitle>

<div class="kiosk-menu">
    <div class="top-bar">
        <button type="button" class="back-btn" @onclick="GoBack">← Back</button>
        <h2>Choose</h2>
        <div class="cart-info">
            Items: @TotalItems | ₱@TotalAmount.ToString("N2")
        </div>
    </div>

    <div class="menu-grid">
        @for (int index = 0; index < MenuItems.Count; index++)
        {
            var item = MenuItems[index];
            var currentIndex = index;
            <div class="menu-item" @key="item.Name">
                <img src="/img/product-1.jpg" alt="@item.Name" />
                <div class="menu-item-body">
                    <h3>@item.Name</h3>
                    <p class="price">₱@item.Price.ToString("N2")</p>

                    <div class="quantity-control" aria-label="Quantity controls">
                        <button type="button" class="qty-btn" aria-label="Decrease quantity" @onclick="() => ChangeQuantity(currentIndex, -1)">−</button>
                        <span class="qty">@item.Quantity</span>
                        <button type="button" class="qty-btn" aria-label="Increase quantity" @onclick="() => ChangeQuantity(currentIndex, 1)">+</button>
                    </div>

                    <button type="button" class="add-to-cart-btn" @onclick="() => AddToCart(currentIndex)" disabled="@(item.Quantity == 0)">
                        Add ₱@(item.Subtotal.ToString("N2"))
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<MenuItem> MenuItems = new();

    private int TotalItems => MenuItems.Sum(x => x.Quantity);
    private decimal TotalAmount => MenuItems.Sum(x => x.Subtotal);

    protected override void OnInitialized()
    {
        MenuItems = new List<MenuItem>
        {
            new MenuItem { Name = "Bato ni Darna", Price = 99, Image = "/pic/pic-1.jpg" }
        };
    }

    private void ChangeQuantity(int index, int change)
    {
        if (index < 0 || index >= MenuItems.Count)
        {
            return;
        }

        var item = MenuItems[index];
        var nextQuantity = Math.Max(0, item.Quantity + change);

        if (item.Quantity != nextQuantity)
        {
            item.Quantity = nextQuantity;
            StateHasChanged();
        }
    }

    private void AddToCart(int index)
    {
        if (index < 0 || index >= MenuItems.Count)
        {
            return;
        }

        var item = MenuItems[index];
        if (item.Quantity > 0)
        {
            NavigationManager.NavigateTo($"/lifecycle/summary?name={Uri.EscapeDataString(item.Name)}&price={item.Price}&quantity={item.Quantity}", forceLoad: false);
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/lifecycle");

    public class MenuItem
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string Image { get; set; } = "";
        public int Quantity { get; set; }
        public decimal Subtotal => Price * Quantity;
    }
}
