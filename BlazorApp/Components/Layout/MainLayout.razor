@inherits LayoutComponentBase

<div class="page-shell">
    <header class="top-nav">
        <div class="brand-mark">Blazor</div>
        <div class="nav-title">Profile Page</div>
    </header>

    <div class="content-shell">
        <main class="main-content">
            @Body
        </main>

        <aside class="side-panel">
            <h4>Samples</h4>

            <div class="hobby-item">
                <h3>Pictures</h3>
                <div class="media-grid">
                    <img src="/pic/pic-1.jpg" alt="Picture 1" />
                    <img src="/pic/pic-2.jpg" alt="Picture 2" />
                    <img src="/pic/pic-3.jpg" alt="Picture 3" />
                </div>
            </div>

            <div class="hobby-item">
                <h3>Video</h3>
                <video controls>
                    <source src="/vid/tiktok-vid.mp4" type="video/mp4">
                    Video player section.
                </video>
            </div>

            <div class="hobby-item">
                <h3>Audio</h3>
                <audio controls>
                    <source src="/msc/tiktok-msc.mp3" type="audio/mpeg">
                    Audio player section.
                </audio>
            </div>
        </aside>
    </div>
</div>