@page "/menu"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Menu</PageTitle>

<div class="kiosk-menu">
    <div class="top-bar">
        <button class="back-btn" @onclick="GoBack">← Back</button>
        <h2>Choose Your Order</h2>
        <div class="cart-info">
            Items: @TotalItems | ₱@TotalAmount.ToString("N2")
        </div>
    </div>

    <div class="menu-grid">
        @foreach (var item in MenuItems)
        {
            <div class="menu-item">
                <img src="@item.Image" width="120" height="120" />
                <h3>@item.Name</h3>
                <p class="price">₱@item.Price.ToString("N2")</p>

                <div class="quantity-control">
                    <button class="qty-btn" @onclick="() => ChangeQuantity(item, -1)" disabled="@(item.Quantity == 0)">−</button>
                    <span class="qty">@item.Quantity</span>
                    <button class="qty-btn" @onclick="() => ChangeQuantity(item, 1)">+</button>
                </div>
            </div>
        }
    </div>

    <div class="checkout-bar">
        <button class="btn btn-primary" @onclick="GoToSummary" disabled="@(TotalItems == 0)">
            Checkout ₱@TotalAmount.ToString("N2")
        </button>
    </div>
</div>

@code {
    private List<MenuItem> MenuItems = new();

    private int TotalItems => MenuItems.Sum(x => x.Quantity);
    private decimal TotalAmount => MenuItems.Sum(x => x.Price * x.Quantity);

    protected override void OnInitialized()
    {
        MenuItems = new List<MenuItem>
        {
            new MenuItem { Name = "Hotpao", Price = 99, Image = "/img/product-1.jpg" },
            // Add more items here
        };
    }

    private void ChangeQuantity(MenuItem item, int change)
    {
        item.Quantity = Math.Max(0, item.Quantity + change);
        StateHasChanged();
    }

    private void GoToSummary()
    {
        CurrentOrder.Items.Clear();

        foreach (var item in MenuItems.Where(i => i.Quantity > 0))
        {
            CurrentOrder.Items.Add(new CurrentOrder.OrderItem 
            { 
                Name = item.Name, 
                Price = item.Price, 
                Quantity = item.Quantity 
            });
        }

        NavigationManager.NavigateTo("/summary");
    }

    private void GoBack() => NavigationManager.NavigateTo("/");

    public class MenuItem
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string Image { get; set; } = "";
        public int Quantity { get; set; } = 0;
    }
}