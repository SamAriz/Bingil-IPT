@page "/summary"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Order Summary</PageTitle>

<div class="summary-page">
    <h1>Your Order Summary</h1>

    <div class="order-list">
        @foreach (var item in CurrentOrder.Items)
        {
            <div class="summary-item">
                <span>@item.Quantity x @item.Name</span>
                <span>₱@((item.Price * item.Quantity).ToString("N2"))</span>
            </div>
        }
    </div>

    <div class="total-section">
        <div class="total-row">
            <strong>Total Items</strong>
            <strong>@CurrentOrder.Items.Sum(x => x.Quantity)</strong>
        </div>
        <div class="total-row grand-total">
            <strong>Total Amount</strong>
            <strong>₱@CurrentOrder.TotalAmount.ToString("N2")</strong>
        </div>
    </div>

    <div class="actions">
        <button class="btn btn-secondary" @onclick="GoBack">← Back to Menu</button>
        <button class="btn btn-primary" @onclick="GoToPayment">Proceed to Payment</button>
    </div>
</div>

@code {
    private void GoBack() => NavigationManager.NavigateTo("/menu");
    private void GoToPayment() => NavigationManager.NavigateTo("/payment");
}