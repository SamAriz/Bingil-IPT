@page "/payment"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Payment</PageTitle>

<div class="payment-page">
    <div class="payment-card">
        <h1>Payment</h1>
        <p><strong>Total Due: ₱@CurrentOrder.TotalAmount.ToString("N2")</strong></p>

        <div class="payment-options">
            <button class="btn btn-primary" @onclick="SelectCash">Cash</button>
            <button class="btn btn-outline-primary" @onclick="SelectCard">Card</button>
        </div>

        @if (SelectedMethod == "Cash")
        {
            <div class="payment-form">
                <label class="form-label">Enter Cash Amount</label>
                <input type="number" class="form-control" @bind="CashAmount" />
                <button class="btn btn-success mt-3" @onclick="ProcessCashPayment">Pay with Cash</button>
            </div>
        }

        @if (SelectedMethod == "Card")
        {
            <div class="payment-form">
                <label class="form-label">Card Number</label>
                <input class="form-control" maxlength="16" @bind="CardNumber" />
                <label class="form-label mt-2">PIN</label>
                <input class="form-control" type="password" maxlength="4" @bind="CardPin" />
                <button class="btn btn-success mt-3" @onclick="ProcessCardPayment">Pay with Card</button>
            </div>
        }

        @if (!string.IsNullOrEmpty(PaymentMessage))
        {
            <div class="alert alert-info mt-3">@PaymentMessage</div>
        }

        @if (ShowReceipt)
        {
            <div class="receipt-card">
                <h3>✅ Receipt</h3>
                <hr />

                @foreach (var item in CurrentOrder.Items)
                {
                    <div class="receipt-row">
                        <span>@item.Quantity x @item.Name</span>
                        <span>₱@((item.Price * item.Quantity).ToString("N2"))</span>
                    </div>
                }

                <hr />
                <div class="receipt-row total">
                    <strong>Total Amount</strong>
                    <strong>₱@CurrentOrder.TotalAmount.ToString("N2")</strong>
                </div>

                <div class="receipt-row">
                    <span>Payment Method</span>
                    <strong>@SelectedMethod</strong>
                </div>

                @if (SelectedMethod == "Cash" && CashAmount > CurrentOrder.TotalAmount)
                {
                    <div class="receipt-row">
                        <span>Change</span>
                        <strong>₱@((CashAmount - CurrentOrder.TotalAmount).ToString("N2"))</strong>
                    </div>
                }
            </div>

            <div class="payment-actions">
                <button class="btn btn-outline-primary" @onclick="GoBackToMenu">← Back to Products</button>
                <button class="btn btn-primary" @onclick="GoToStart">Return to Start</button>
            </div>
        }
    </div>
</div>

@code {
    private decimal CashAmount { get; set; }
    private string SelectedMethod { get; set; } = "";
    private string CardNumber { get; set; } = "";
    private string CardPin { get; set; } = "";
    private string PaymentMessage { get; set; } = "";
    private bool ShowReceipt { get; set; } = false;

    private void SelectCash()
    {
        SelectedMethod = "Cash";
        PaymentMessage = "";
        ShowReceipt = false;
    }

    private void SelectCard()
    {
        SelectedMethod = "Card";
        PaymentMessage = "";
        ShowReceipt = false;
    }

    private void ProcessCashPayment()
    {
        if (CashAmount >= CurrentOrder.TotalAmount)
        {
            ShowReceipt = true;
            PaymentMessage = "Payment successful! Thank you!";
        }
        else
        {
            PaymentMessage = "Insufficient cash amount!";
        }
        StateHasChanged();
    }

    private void ProcessCardPayment()
    {
        if (!string.IsNullOrWhiteSpace(CardNumber) && !string.IsNullOrWhiteSpace(CardPin))
        {
            ShowReceipt = true;
            PaymentMessage = "Card payment successful!";
        }
        else
        {
            PaymentMessage = "Please enter card details.";
        }
        StateHasChanged();
    }

    private void GoBackToMenu() => NavigationManager.NavigateTo("/menu");
    private void GoToStart() => NavigationManager.NavigateTo("/");
}